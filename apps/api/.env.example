# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/clario?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT (use a long random secret in production)
JWT_SECRET="change-me-min-16-chars-minimum"
JWT_EXPIRES_IN=7d

# AI provider: openai | gemini (default: openai)
AI_PROVIDER=openai

# OpenAI — required when AI_PROVIDER=openai
OPENAI_API_KEY="sk-..."
OPENAI_MODEL=gpt-4o-mini

# Google Gemini — required when AI_PROVIDER=gemini (optional when using OpenAI only; both keys enable fallback)
GEMINI_API_KEY=""
# Stable id (older aliases like gemini-1.5-flash may be retired — check Google docs)
GEMINI_MODEL=gemini-2.5-flash
