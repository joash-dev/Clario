# Copy to `.env` in this folder (Expo loads EXPO_PUBLIC_* at startup).
# Base URL MUST include `/api/v1` (see apps/api — routes are under /api/v1).

# Same machine — web / iOS Simulator:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Android emulator (localhost on your PC):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000/api/v1

# Physical phone / tablet — use your computer's LAN IP (not localhost):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:3000/api/v1
#
# Windows: run `ipconfig` and use IPv4 Address of your active adapter.
# Restart `npx expo start` after changing this file.
